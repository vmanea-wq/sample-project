{
  "name": "sample-project-ci-cd",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build:vite": "vite build",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:report": "mkdir -p qa/reports && eslint . -f json -o qa/reports/eslint-report.json",
    "lint:complexity": "node qa/scripts/complexity-scan.mjs",
    "test": "bash scripts/vitest-with-safe-path.sh run",
    "test:watch": "vitest",
    "test:coverage": "bash scripts/vitest-with-safe-path.sh run --coverage",
    "preview": "vite preview",
    "qa:preview": "vite preview --host 127.0.0.1 --port 4173",
    "qa:complexity": "node qa/scripts/complexity-scan.mjs",
    "qa:dashboard": "node qa/scripts/build-dashboard.mjs",
    "qa:e2e": "playwright test",
    "qa:k6": "bash scripts/k6-run.sh",
    "qa:zap": "bash scripts/zap-baseline.sh",
    "qa:snyk": "bash scripts/snyk-scan.sh",
    "qa:all": "bash scripts/run-qa.sh",
    "pylint": "pylint qa/python"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^17.4.4",
    "jsdom": "^26.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.4"
  }
}
